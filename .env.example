# ─────────────────────────────────────────────────────────────────
# Feature Flag Engine — Environment Variables
# Copy this file to .env and fill in values before running.
# For local Docker Compose: defaults work as-is.
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────
DATABASE_URL=postgres://ffee:ffee_secret@localhost:5432/featureflags?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── API Server ───────────────────────────────────────────────────
SERVER_PORT=8080
METRICS_PORT=9090

# ── Application ──────────────────────────────────────────────────
LOG_LEVEL=info          # debug | info | warn | error
ENV=development         # development | staging | production
