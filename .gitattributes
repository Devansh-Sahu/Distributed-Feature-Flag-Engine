# Normalize line endings
# All text files use LF in the repo, converted to OS line endings on checkout
* text=auto eol=lf

# Force LF for specific file types (important for Docker + shell scripts)
*.go    text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.env*  text eol=lf
Dockerfile* text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
